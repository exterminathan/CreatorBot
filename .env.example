# Copy this file to .env and fill in the values below.
# Never commit .env — it's gitignored.

# Discord bot token — Discord Developer Portal → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Password for the web admin control panel (pick any strong string).
# Blank disables password protection (not recommended in production).
WEB_PASSWORD=
